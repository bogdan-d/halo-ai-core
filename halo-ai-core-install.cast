[23.08, "o", "  1. Open http://localhost:13305 \u2014 load a model, start chatting\r\n"]
[23.16, "o", "  2. Launch Claude Code with local models:\r\n"]
[23.24, "o", "     lemonade launch claude -m <model-name>\r\n"]
[23.32, "o", "  3. Check status:\r\n"]
[23.4, "o", "     ./install.sh --status\r\n"]
[23.45, "o", "\r\n"]
