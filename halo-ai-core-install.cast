{"version":3,"term":{"cols":0,"rows":0,"type":"xterm-256color"},"timestamp":1775663542,"command":"bash -c \"\n  bash ~/halo-ai-core/install.sh --yes-all\n\n  echo\n  echo ══════════════════════════════════════\n  echo    VERIFY — Services Running\n  echo ══════════════════════════════════════\n  echo\n  systemctl is-active caddy llama-server lemonade-ui gaia-ui 2>/dev/null || true\n  echo\n  echo Caddy status:\n  systemctl status caddy --no-pager -l 2>&1 | head -10\n  echo\n\n  echo ══════════════════════════════════════\n  echo    BENCHMARKS — Out of the Box\n  echo ══════════════════════════════════════\n  echo\n  echo Downloading Qwen3-30B-A3B Q4_K_M 18GB...\n  mkdir -p ~/models\n  curl -sL -o ~/models/Qwen3-30B-A3B-Q4_K_M.gguf https://huggingface.co/unsloth/Qwen3-30B-A3B-GGUF/resolve/main/Qwen3-30B-A3B-Q4_K_M.gguf\n  echo Model ready — running benchmarks...\n  source /etc/profile.d/rocm.sh\n  llama-bench -m ~/models/Qwen3-30B-A3B-Q4_K_M.gguf -ngl 99 -p 512 -n 128\n  echo\n  echo ══════════════════════════════════════\n  echo    Done. Clone it. Install it. Ship it.\n  echo    https://github.com/stampby/halo-ai-core\n  echo ══════════════════════════════════════\n\"","env":{"SHELL":"/usr/bin/bash"}}
