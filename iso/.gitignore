out/

# Staged overlay contents — regenerated by stage-binaries.sh on every build.
# The tar extraction dumps ~1.8 GB of model + binaries here. We want the
# profile DIR committed (structure + motd + halo-install scripts), but not
# the swap-every-release binary tree.
profile/airootfs/usr/local/bin/bitnet_decode
profile/airootfs/usr/local/bin/agent_cpp
profile/airootfs/usr/local/lib/librocm_cpp.so
profile/airootfs/opt/halo-ai/models/
profile/airootfs/etc/skel/halo-ai-core/
profile/airootfs/etc/skel/claude-state.tar.gz
