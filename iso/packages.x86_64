# ============================================================
# Halo AI Core ISO — Package List
# These packages are included in the live ISO environment
# ============================================================

# Archiso required
mkinitcpio
mkinitcpio-archiso

# Base system
base
linux
linux-firmware
linux-headers

# Microcode
amd-ucode

# Boot
syslinux
edk2-shell

# Filesystem tools
btrfs-progs
dosfstools
e2fsprogs
xfsprogs
f2fs-tools
ntfs-3g

# Partitioning
parted
gptfdisk

# Arch installation
arch-install-scripts
archinstall

# Network
dhcpcd
iwd
networkmanager
openssh
curl
wget

# Wireless (for portability)
broadcom-wl
wireless-regdb

# Editors & tools
nano
vim
git
htop
tmux
less
man-db

# Hardware detection
pciutils
usbutils
dmidecode
lshw

# GPU / ROCm (pre-staged for install.sh)
vulkan-tools
vulkan-headers
vulkan-icd-loader
vulkan-radeon

# Python (for archinstall + scripting)
python
python-pip

# Build tools (needed for post-install compilation)
base-devel
cmake
rust

# Node.js (needed for Claude Code)
nodejs
npm

# System management
cpupower
nftables
wireguard-tools
qrencode

# Display / TTY
dialog
terminus-font
