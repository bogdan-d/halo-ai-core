#!/usr/bin/env bash
# halo-ai-core PXE bootstrap — fresh-box bring-up.
#
# Flow:
#   1. Arch live env is already booted over PXE.
#   2. This script wipes the target disk, installs Arch, copies Claude
#      state from strixhalo, kicks off halo-ai-core install.sh.
#
# Invocation:
#   curl -sSL http://strixhalo.lan:8000/bootstrap.sh | bash
#
# "Release the hard drives from grub" — first thing we do is wipe any
# existing bootloader off the target disks.
set -euo pipefail

BOOTSTRAP_HOST="${BOOTSTRAP_HOST:-10.0.0.10}"    # strixhalo
TARGET_DISK="${TARGET_DISK:-/dev/nvme0n1}"
TARGET_USER="${TARGET_USER:-bcloud}"
TARGET_HOSTNAME="${TARGET_HOSTNAME:-halo-test}"

c_blue='\033[0;36m'; c_green='\033[0;32m'; c_yellow='\033[1;33m'; c_red='\033[0;31m'; c_off='\033[0m'
log()  { echo -e "${c_blue}[pxe-bootstrap]${c_off} $1"; }
ok()   { echo -e "${c_green}[✓]${c_off} $1"; }
warn() { echo -e "${c_yellow}[!]${c_off} $1"; }
die()  { echo -e "${c_red}[✗]${c_off} $1"; exit 1; }

# ── guard rails ─────────────────────────────────────────────────
[[ "$(id -u)" == "0" ]] || die "must run as root (we repartition disks)"
[[ -b "$TARGET_DISK" ]] || die "$TARGET_DISK is not a block device"
log "target disk: $TARGET_DISK"
log "bootstrap host: $BOOTSTRAP_HOST"
lsblk "$TARGET_DISK" || true
echo
echo -e "${c_red}this will ERASE $TARGET_DISK${c_off}"
read -rp "type YES to continue: " confirm
[[ "$confirm" == "YES" ]] || die "aborted"

# ── step 1: release the hard drives from GRUB ──────────────────
log "step 1/6: releasing $TARGET_DISK from any existing bootloader"
# dd first 100 MiB to obliterate GRUB MBR + ESP headers
dd if=/dev/zero of="$TARGET_DISK" bs=1M count=100 conv=fsync status=progress
wipefs -af "$TARGET_DISK"
sgdisk --zap-all "$TARGET_DISK"
partprobe "$TARGET_DISK" || true
ok "disk released, GRUB evicted"

# ── step 2: fresh GPT + partitions ──────────────────────────────
log "step 2/6: writing fresh GPT"
sgdisk --new=1:0:+1G    --typecode=1:EF00 --change-name=1:ESP   "$TARGET_DISK"
sgdisk --new=2:0:+8G    --typecode=2:8200 --change-name=2:swap  "$TARGET_DISK"
sgdisk --new=3:0:0      --typecode=3:8300 --change-name=3:root  "$TARGET_DISK"
partprobe "$TARGET_DISK"
sleep 1
P1="${TARGET_DISK}p1"; P2="${TARGET_DISK}p2"; P3="${TARGET_DISK}p3"
[[ -b "$P1" && -b "$P2" && -b "$P3" ]] || die "partitions didn't materialise"
mkfs.vfat -F32 -n ESP "$P1"
mkswap -L swap "$P2"
mkfs.btrfs -f -L root "$P3"
ok "partitions ready"

# ── step 3: btrfs subvolumes + mount ────────────────────────────
log "step 3/6: creating btrfs subvolume layout (@, @home, @log, @pkg)"
mount "$P3" /mnt
btrfs subvolume create /mnt/@
btrfs subvolume create /mnt/@home
btrfs subvolume create /mnt/@log
btrfs subvolume create /mnt/@pkg
btrfs subvolume create /mnt/@.snapshots
umount /mnt
OPTS="noatime,compress=zstd:3,ssd,discard=async,space_cache=v2"
mount -o "${OPTS},subvol=@"       "$P3" /mnt
mkdir -p /mnt/{home,var/log,var/cache/pacman/pkg,.snapshots,boot}
mount -o "${OPTS},subvol=@home"       "$P3" /mnt/home
mount -o "${OPTS},subvol=@log"        "$P3" /mnt/var/log
mount -o "${OPTS},subvol=@pkg"        "$P3" /mnt/var/cache/pacman/pkg
mount -o "${OPTS},subvol=@.snapshots" "$P3" /mnt/.snapshots
mount "$P1" /mnt/boot
swapon "$P2" || true
ok "subvolumes mounted"

# ── step 4: pacstrap base system ────────────────────────────────
log "step 4/6: pacstrap (this takes ~5 min)"
pacstrap /mnt base base-devel linux linux-firmware btrfs-progs \
    networkmanager sudo openssh git rsync nodejs npm vim which \
    cmake ninja python python-pip \
    amd-ucode efibootmgr systemd-boot-manager 2>/dev/null || \
pacstrap /mnt base base-devel linux linux-firmware btrfs-progs \
    networkmanager sudo openssh git rsync nodejs npm vim which \
    cmake ninja python python-pip amd-ucode efibootmgr
genfstab -U /mnt > /mnt/etc/fstab
ok "base system installed"

# ── step 5: chroot setup + bootloader + user ────────────────────
log "step 5/6: configuring base system"
cat > /mnt/root/finalise.sh <<FINAL
#!/bin/bash
set -e
ln -sf /usr/share/zoneinfo/America/Edmonton /etc/localtime
hwclock --systohc || true
echo "en_US.UTF-8 UTF-8" > /etc/locale.gen
locale-gen
echo "LANG=en_US.UTF-8" > /etc/locale.conf
echo "${TARGET_HOSTNAME}" > /etc/hostname
cat > /etc/hosts <<EOF
127.0.0.1   localhost
::1         localhost
127.0.1.1   ${TARGET_HOSTNAME}
EOF
systemctl enable NetworkManager sshd
bootctl install
cat > /boot/loader/loader.conf <<EOF
default arch.conf
timeout 3
console-mode max
editor no
EOF
cat > /boot/loader/entries/arch.conf <<EOF
title   halo-ai-core
linux   /vmlinuz-linux
initrd  /amd-ucode.img
initrd  /initramfs-linux.img
options root=LABEL=root rootflags=subvol=@ rw quiet
EOF
useradd -m -G wheel -s /bin/bash ${TARGET_USER}
echo "${TARGET_USER} ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/10-${TARGET_USER}
echo "${TARGET_USER}:temp-reset-me" | chpasswd
FINAL
chmod +x /mnt/root/finalise.sh
arch-chroot /mnt /root/finalise.sh
ok "base configured, bootloader installed"

# ── step 6: Claude state + halo-ai-core ─────────────────────────
log "step 6/6: fetching Claude state + halo-ai-core"
mkdir -p "/mnt/home/${TARGET_USER}"
# Pull the tarball (served by bootstrap host's HTTP)
curl -fsSL "http://${BOOTSTRAP_HOST}:8000/claude-state.tar.gz" \
    -o /mnt/root/claude-state.tar.gz
tar -xzf /mnt/root/claude-state.tar.gz -C "/mnt/home/${TARGET_USER}/"
# halo-ai-core from our bootstrap host (fresh clone, authoritative)
arch-chroot /mnt sudo -u "${TARGET_USER}" bash -c "
    git clone https://github.com/stampby/halo-ai-core.git ~/halo-ai-core
    git clone https://github.com/stampby/rocm-cpp.git      ~/rocm-cpp
    git clone https://github.com/stampby/agent-cpp.git     ~/agent-cpp
    git clone https://github.com/stampby/halo-1bit.git     ~/halo-1bit
"
arch-chroot /mnt chown -R "${TARGET_USER}:${TARGET_USER}" "/home/${TARGET_USER}"
# Install claude-code CLI so the box boots with Claude ready
arch-chroot /mnt npm install -g @anthropic-ai/claude-code || warn "claude-code install failed — re-run post-boot"
ok "Claude state + repos staged"

log "done. reboot the target, log in as ${TARGET_USER}, run:"
echo "  cd ~/halo-ai-core && ./install.sh --yes-all"
