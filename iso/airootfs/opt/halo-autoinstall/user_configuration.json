{
    "config_version": "2.8.6",
    "additional-repositories": [],
    "archinstall-language": "English",
    "bootloader": "Systemd-boot",
    "debug": false,
    "disk_config": {
        "config_type": "default_layout",
        "device_modifications": [
            {
                "device": null,
                "wipe": true,
                "partitions": [
                    {
                        "btrfs": [],
                        "flags": ["Boot"],
                        "fs_type": "fat32",
                        "mount_options": [],
                        "mountpoint": "/boot",
                        "size": {
                            "sector_size": null,
                            "unit": "MiB",
                            "value": 1024
                        },
                        "status": "create",
                        "type": "primary"
                    },
                    {
                        "btrfs": [
                            {"mountpoint": "/", "name": "@"},
                            {"mountpoint": "/home", "name": "@home"},
                            {"mountpoint": "/var/log", "name": "@log"},
                            {"mountpoint": "/var/cache/pacman/pkg", "name": "@pkg"},
                            {"mountpoint": "/.snapshots", "name": "@snapshots"}
                        ],
                        "flags": [],
                        "fs_type": "btrfs",
                        "mount_options": ["compress=zstd:3", "noatime", "space_cache=v2", "ssd"],
                        "mountpoint": null,
                        "size": {
                            "sector_size": null,
                            "unit": "Remainder",
                            "value": 100
                        },
                        "status": "create",
                        "type": "primary"
                    }
                ]
            }
        ]
    },
    "hostname": "strix-halo",
    "kernels": ["linux"],
    "locale_config": {
        "kb_layout": "us",
        "sys_enc": "UTF-8",
        "sys_lang": "en_US"
    },
    "mirror_config": {
        "mirror_regions": {
            "Canada": [
                "https://mirror.csclub.uwaterloo.ca/archlinux/$repo/os/$arch",
                "https://archlinux.mirror.colo-serv.net/$repo/os/$arch",
                "https://mirror.cedar.buffalo.edu/archlinux/$repo/os/$arch"
            ],
            "United States": [
                "https://mirror.rackspace.com/archlinux/$repo/os/$arch",
                "https://mirrors.kernel.org/archlinux/$repo/os/$arch",
                "https://mirrors.rit.edu/archlinux/$repo/os/$arch"
            ]
        }
    },
    "network_config": {
        "type": "nm"
    },
    "no_pkg_lookups": false,
    "ntp": true,
    "packages": [
        "base-devel",
        "git",
        "openssh",
        "networkmanager",
        "curl",
        "wget",
        "htop",
        "nano",
        "vim",
        "tmux",
        "nodejs",
        "npm",
        "uv",
        "linux-firmware",
        "linux-headers",
        "vulkan-tools",
        "vulkan-headers",
        "vulkan-icd-loader",
        "vulkan-radeon",
        "btrfs-progs",
        "cpupower",
        "nftables",
        "wireguard-tools",
        "qrencode",
        "pciutils",
        "usbutils",
        "dmidecode",
        "lshw",
        "python",
        "python-pip",
        "python-psutil",
        "cmake",
        "rust",
        "less",
        "man-db",
        "amd-ucode"
    ],
    "parallel downloads": 16,
    "profile_config": {
        "gfx_driver": "All open-source",
        "profile": {
            "main": "Minimal"
        }
    },
    "swap": true,
    "timezone": "America/Halifax",
    "custom_commands": [
        "systemctl enable NetworkManager",
        "systemctl enable sshd",
        "systemctl enable cpupower",
        "echo 'governor=performance' > /etc/default/cpupower",
        "echo 'net.ipv4.ip_forward=1' > /etc/sysctl.d/99-ip-forward.conf",
        "sed -i 's/^#ParallelDownloads.*/ParallelDownloads = 16/' /etc/pacman.conf",
        "echo '# Halo AI Core — post-install will run on first boot' > /root/.halo-pending"
    ]
}
