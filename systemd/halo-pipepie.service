[Unit]
Description=Pipepie — Encrypted Tunnel Server
After=network.target

[Service]
Type=simple
User=<YOUR_USER>
Group=<YOUR_USER>
WorkingDirectory=/srv/ai/pipepie
ExecStart=/usr/local/bin/pie server --config /srv/ai/configs/pipepie.yaml
Restart=on-failure
RestartSec=5
ProtectSystem=strict
PrivateTmp=yes
NoNewPrivileges=yes
ProtectHome=read-only
ReadWritePaths=/srv/ai

[Install]
WantedBy=multi-user.target
