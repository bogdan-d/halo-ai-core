{
	admin "unix//run/caddy/admin.socket"
}

:80 {
	@local remote_ip 127.0.0.1 ::1 10.0.0.0/24 10.100.0.0/24 192.168.101.0/24

	# All /api/* routes — local only, pass straight to stats server
	handle /api/* {
		handle @local {
			reverse_proxy 127.0.0.1:5090
		}
		respond 403
	}

	# Legacy stats routes
	handle /stats {
		handle @local {
			reverse_proxy 127.0.0.1:5090
		}
		respond 403
	}
	handle /models {
		handle @local {
			reverse_proxy 127.0.0.1:5090
		}
		respond 403
	}
	handle /exec* {
		handle @local {
			reverse_proxy 127.0.0.1:5090
		}
		respond 403
	}

	# Whisper transcription proxy — local only
	handle_path /api/transcribe {
		handle @local {
			rewrite * /transcribe
			reverse_proxy 127.0.0.1:8082
		}
		respond 403
	}

	# Lemonade API proxy — local only
	handle /v1/* {
		handle @local {
			reverse_proxy 127.0.0.1:13305
		}
		respond 403
	}

	# Lemonade web app — proxy on /lemonade path
	handle /lemonade* {
		handle @local {
			uri strip_prefix /lemonade
			reverse_proxy 127.0.0.1:13305 {
				header_down -Content-Security-Policy
			}
		}
		respond 403
	}

	# Dashboard (static files)
	root * /srv/halo-dashboard
	file_server
}

import /etc/caddy/conf.d/*.caddy
