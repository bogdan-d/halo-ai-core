{
	admin "unix//run/caddy/admin.socket"
}

http:// {
	# Lemonade reverse proxy (all /v1/ API + websocket + UI)
	handle /v1/* {
		reverse_proxy 127.0.0.1:13305
	}

	# Gaia reverse proxy
	handle /gaia/* {
		uri strip_prefix /gaia
		reverse_proxy 127.0.0.1:4200
	}

	# Gaia API
	handle /api/gaia/* {
		uri strip_prefix /api/gaia
		reverse_proxy 127.0.0.1:5050
	}

	# Dashboard (fallback — serves index.html)
	root * /srv/halo-dashboard
	file_server
}
